{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./src/*"]
		},
		"jsx": "preserve",
		"noEmit": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"incremental": true,
		"allowJs": true
	},
	"include": ["src", "next-env.d.ts", ".next/types/**/*.ts", "event.config.ts"],
	"exclude": ["node_modules"]
}
